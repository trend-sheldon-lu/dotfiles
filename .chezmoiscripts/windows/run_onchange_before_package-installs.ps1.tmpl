{{ if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = 'Continue'

# Helper: install a winget package only if not already present
function Install-WingetPackage {
    param(
        [string]$Id,
        [string]$Source = "winget"
    )
    winget list --id $Id -e --accept-source-agreements | Out-Null
    if ($LASTEXITCODE -eq 0) {
        Write-Host "Already installed: $Id" -ForegroundColor Green
    } else {
        Write-Host "Installing: $Id..." -ForegroundColor Yellow
        winget install --source $Source --accept-package-agreements --uninstall-previous $Id
    }
}

# Install PowerShell modules
{{ range .packages.windows.powershell -}}
if (-not (Get-Module {{ . | quote }} -ListAvailable -ErrorAction SilentlyContinue)) {
    Write-Host "Installing PS module: {{ . }}..." -ForegroundColor Yellow
    Install-Module {{ . | quote }} -Scope CurrentUser -Force -SkipPublisherCheck
} else {
    Write-Host "PS module already installed: {{ . }}" -ForegroundColor Green
}
{{ end -}}

# Core winget packages
{{ range .packages.windows.winget -}}
Install-WingetPackage -Id {{ . | quote }}
{{ end -}}

{{ if eq .ptxmode true }}
{{ range .packages.windows.ptxmode.winget -}}
Install-WingetPackage -Id {{ . | quote }}
{{ end -}}
{{ end }}

{{ if eq .pmode true }}
{{ range .packages.windows.pmode.winget -}}
Install-WingetPackage -Id {{ . | quote }}
{{ end -}}
{{ end }}

{{ if eq .oagmode true }}
{{ range .packages.windows.oagmode.winget -}}
Install-WingetPackage -Id {{ . | quote }}
{{ end -}}
{{ end }}

{{ range .packages.windows.msstore -}}
Install-WingetPackage -Id {{ . | quote }} -Source "msstore"
{{ end -}}

$env:Path = [System.Environment]::GetEnvironmentVariable("Path","Machine") + ";" + [System.Environment]::GetEnvironmentVariable("Path","User")
# Check if codeium is installed and create alias for code
if (Get-Command codium -ErrorAction SilentlyContinue) {
    Write-Host "Codium found. Creating alias for code..." -ForegroundColor Yellow
    Set-Alias -Name code -Value codium -Scope Local -Force
}

{{ range .extensions.windows.vscode -}}
if (-not (code --list-extensions | Select-String -SimpleMatch {{ . | quote }})) {
    Write-Host "Installing VS Code extension: {{ . }}..." -ForegroundColor Yellow
    code --force --install-extension {{ . | quote }}
} else {
    Write-Host "VS Code extension already installed: {{ . }}" -ForegroundColor Green
}
{{ end -}}

{{ end -}}
