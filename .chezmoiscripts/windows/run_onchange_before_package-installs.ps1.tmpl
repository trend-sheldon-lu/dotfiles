{{ if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = 'Continue'

$dscConfigPath = Join-Path $env:TEMP "chezmoi-winget-config.yaml"

@"
# yaml-language-server: `$schema=https://aka.ms/configuration-dsc-schema/0.3
`$schema: https://raw.githubusercontent.com/PowerShell/DSC/main/schemas/2023/08/config/document.json
metadata:
  winget:
    processor:
      identifier: "dscv3"
resources:
{{- range .packages.windows.winget }}
  - name: winget_{{ . }}
    type: Microsoft.WinGet/Package
    properties:
      id: {{ . | quote }}
      source: "winget"
{{- end }}

{{- if hasKey . "ptxmode" }}
{{- if eq .ptxmode true }}
{{- range .packages.windows.ptxmode.winget }}
  - name: winget_{{ . }}
    type: Microsoft.WinGet/Package
    properties:
      id: {{ . | quote }}
      source: "winget"
{{- end }}
{{- end }}
{{- end }}

{{- if hasKey . "pmode" }}
{{- if eq .pmode true }}
{{- range .packages.windows.pmode.winget }}
  - name: winget_{{ . }}
    type: Microsoft.WinGet/Package
    properties:
      id: {{ . | quote }}
      source: "winget"
{{- end }}
{{- end }}
{{- end }}

{{- if hasKey . "oagmode" }}
{{- if eq .oagmode true }}
{{- range .packages.windows.oagmode.winget }}
  - name: winget_{{ . }}
    type: Microsoft.WinGet/Package
    properties:
      id: {{ . | quote }}
      source: "winget"
{{- end }}
{{- end }}
{{- end }}

{{- range .packages.windows.msstore }}
  - name: msstore_{{ . }}
    type: Microsoft.WinGet/Package
    properties:
      id: {{ . | quote }}
      source: "msstore"
{{- end }}

{{- range .packages.windows.powershell }}
  - name: psmodule_{{ . }}
    type: Microsoft.PowerShell.PSResourceGet/PSResource
    settings:
      Name: {{ . | quote }}
      Ensure: "Present"
{{- end }}

  - name: VSCodium_Extensions
    type: PSDscResources/Script
    dependsOn:
      - winget_VSCodium.VSCodium
    settings:
      TestScript: |
        `$required = @(
{{- range .extensions.windows.vscode }}
          {{ . | quote }},
{{- end }}
          ""
        ) | Where-Object { `$_.Trim() -ne "" }
        `$installed = codium --list-extensions
        foreach (`$id in `$required) {
            if (`$id -notin `$installed) { return `$false }
        }
        return `$true
      SetScript: |
        `$required = @(
{{- range .extensions.windows.vscode }}
          {{ . | quote }},
{{- end }}
          ""
        ) | Where-Object { `$_.Trim() -ne "" }
        `$installed = codium --list-extensions
        foreach (`$id in `$required) {
            if (`$id -notin `$installed) {
                Write-Host "Installing extension: `$id"
                codium --install-extension `$id --force
            }
        }
      GetScript: |
        return @{ Result = "VSCodium Extensions Management" }
"@ | Out-File -FilePath $dscConfigPath -Encoding utf8

Write-Host "Applying WinGet DSC configuration..." -ForegroundColor Yellow
winget configure --file $dscConfigPath --accept-configuration-agreements

$env:Path = [System.Environment]::GetEnvironmentVariable("Path","Machine") + ";" + [System.Environment]::GetEnvironmentVariable("Path","User")
# Check if codium is installed and create alias for code
if (Get-Command codium -ErrorAction SilentlyContinue) {
    Write-Host "Codium found. Creating alias for code..." -ForegroundColor Yellow
    Set-Alias -Name code -Value codium -Scope Local -Force
}

{{ end -}}
